DULLAHAN_ENV=local
DULLAHAN_LOG_LEVEL=INFO
DULLAHAN_INFERENCE_CONFIG=configs/inference.yaml
EDL_MODEL_PROVIDER=deterministic
EDL_MODEL_BASE_URL=http://127.0.0.1:30000/v1
EDL_MODEL_TIMEOUT_SECONDS=30
EDL_MAX_DISPATCH_CONCURRENCY=16
AGENT_PLANNER_PROVIDER=deterministic
AGENT_PLANNER_BASE_URL=http://127.0.0.1:30000/v1
AGENT_PLANNER_MODEL=local-planner
AGENT_PLANNER_TIMEOUT_SECONDS=30
