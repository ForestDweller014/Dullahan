VLLM_VERSION=0.24.0
MODEL_ADMIN_TOKEN=replace-with-a-long-random-secret
HF_TOKEN=
# Default package export: full or lora_only. Requests may override this with ?mode=.
MODEL_EXPORT_MODE=full
# LoRA slots per execution batch and adapters retained in host-memory cache.
VLLM_MAX_LORAS=4
VLLM_MAX_CPU_LORAS=8
