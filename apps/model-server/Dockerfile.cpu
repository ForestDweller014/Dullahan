ARG CPU_BASE_IMAGE=dullahan/vllm-cpu-base:0.24.0
FROM ${CPU_BASE_IMAGE}

USER root
WORKDIR /opt/dullahan
COPY server/requirements.txt /tmp/manager-requirements.txt
RUN python -m pip install --no-cache-dir -r /tmp/manager-requirements.txt
COPY server /opt/dullahan/server
RUN chmod +x /opt/dullahan/server/entrypoint.sh

ENV MODEL_ROOT=/models \
    MANAGER_PORT=8080 \
    VLLM_HOST=127.0.0.1 \
    VLLM_PORT=8000 \
    VLLM_TARGET_DEVICE=cpu \
    DULLAHAN_BACKEND=cpu
VOLUME ["/models"]
EXPOSE 8080
ENTRYPOINT ["/opt/dullahan/server/entrypoint.sh"]
